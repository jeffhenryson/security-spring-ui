{
  "name": "security-spring-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "tw:build": "tailwindcss -i ./src/tailwind.css -o ./src/tailwind-generated.css",
    "tw:watch": "tailwindcss -i ./src/tailwind.css -o ./src/tailwind-generated.css --watch",
    "start": "concurrently \"npm run tw:watch\" \"ng serve --port 4200\"",
    "build": "npm run tw:build && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\"",
    "ci": "npm run format:check && npm run lint && npm test",
    "size": "size-limit",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "generate:api": "ng-openapi-gen",
    "fetch:spec": "bash scripts/fetch-openapi-spec.sh"
  },
  "size-limit": [
    {
      "name": "Initial bundle (main)",
      "path": "dist/security-spring-ui/browser/main*.js",
      "limit": "500 KB"
    },
    {
      "name": "All JS combined",
      "path": "dist/security-spring-ui/browser/*.js",
      "limit": "2 MB"
    }
  ],
  "private": true,
  "packageManager": "npm@9.2.0",
  "dependencies": {
    "@angular/animations": "^21.2.14",
    "@angular/cdk": "^21.2.13",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.13",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@sentry/angular": "^10.55.0",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular-eslint/eslint-plugin-template": "^21.4.0",
    "@angular-eslint/template-parser": "^21.4.0",
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.15",
    "@fontsource/roboto": "^5.2.10",
    "@playwright/test": "^1.60.0",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/cli": "^4.3.0",
    "@types/jest": "^30.0.0",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "concurrently": "^10.0.0",
    "eslint": "^10.4.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-preset-angular": "^16.1.5",
    "material-icons": "^1.13.14",
    "material-symbols": "^0.44.10",
    "ng-openapi-gen": "^1.0.5",
    "prettier": "^3.8.1",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2"
  }
}
